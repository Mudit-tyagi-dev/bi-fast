# REST API base URL (used for health check + /config/rooms)
VITE_API_URL=https://biz-dash-backend.onrender.com

# WebSocket base URL (used for /ws/{room_id})
# In development, Vite proxies /ws → ws://localhost:8000/ws
# In production, change this to your deployed WS server
VITE_WS_URL=wss://biz-dash-backend.onrender.com
